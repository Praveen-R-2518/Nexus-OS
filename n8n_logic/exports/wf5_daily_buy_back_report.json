      "id": "c34ddfee-54f4-4c50-b556-563987bbaad0",
      "name": "Build Report Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        560
      ],
      "parameters": {
        "jsCode": "const s = $('Aggregate Stats').first().json;\nconst template = [\n  `${s.business_name} daily brief for ${s.date}: ${s.total_conversations} conversations processed with LKR ${s.revenue_at_risk} revenue at risk.`,\n  `${s.replies_drafted} reply drafts were prepared and ${s.followups_scheduled} follow-ups scheduled, saving about ${s.hours_saved} hours.`,\n  `${s.hot_leads_count} hot leads and ${s.churn_risks_count} churn risks still need founder attention today.`,\n  `Review pending drafts and respond to the highest-value hot lead first.`\n].join(' ');\n\n// The report-summary endpoint (app-hosted OpenAI) already falls back to a labelled\n// summary when the key is missing or the call fails — this template only covers a\n// hard network/transport failure reaching the app itself.\nconst ai = $('Generate AI Summary (via app)').first().json || {};\nconst text = String(ai.summary || '').trim();\n\nreturn [{ json: { text: text || template, summary_source: ai.source || 'template' } }];"
      }
    },
