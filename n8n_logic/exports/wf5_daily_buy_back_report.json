    {
      "parameters": {
        "jsCode": "const rowsFrom = (nodeName) => {\n  const rows = [];\n\n  for (const item of $(nodeName).all()) {\n    const data = item.json;\n\n    if (Array.isArray(data?.body)) {\n      rows.push(...data.body);\n    } else if (Array.isArray(data)) {\n      rows.push(...data);\n    } else if (Array.isArray(data?.data)) {\n      rows.push(...data.data);\n    } else if (data && typeof data === 'object' && Object.keys(data).length > 0) {\n      rows.push(data);\n    }\n  }\n\n  return rows;\n};\n\nconst conversations = rowsFrom('Get Total Conversations Today');\nconst hotLeads      = rowsFrom('Get Hot Leads');\nconst churnRisks    = rowsFrom('Get Churn Risks');\nconst replies       = rowsFrom('Get Replies Drafted Today');\nconst followups     = rowsFrom('Get Pending Follow-ups');\nconst revenueItems  = rowsFrom('Get Revenue At Risk');\nconst profile       = rowsFrom('Get Business Profile');\n\nconst totalConversations = conversations.length;\nconst hotLeadsCount      = hotLeads.length;\nconst churnRisksCount    = churnRisks.length;\nconst repliesDrafted     = replies.length;\nconst followupsScheduled = followups.length;\n\nconst revenueAtRisk = revenueItems.reduce((sum, item) => {\n  return sum + (parseFloat(item.estimated_value) || 0);\n}, 0);\n\nconst hoursSaved = ((repliesDrafted * 12) + (followupsScheduled * 8)) / 60;\nconst businessName = profile[0]?.name ?? 'the business';\n\nreturn [{\n  json: {\n    business_name:        businessName,\n    date:                 new Date().toISOString().split('T')[0],\n    total_conversations:  totalConversations,\n    hot_leads_count:      hotLeadsCount,\n    churn_risks_count:    churnRisksCount,\n    replies_drafted:      repliesDrafted,\n    replies_sent:         repliesDrafted,\n    followups_scheduled:  followupsScheduled,\n    revenue_at_risk:      Math.round(revenueAtRisk),\n    hours_saved:          Math.round(hoursSaved * 10) / 10\n  }\n}];"
      },
