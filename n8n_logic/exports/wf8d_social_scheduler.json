              "value": "=Bearer {{ $vars.N8N_INGEST_TOKEN }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "c28f431c-d243-4f92-9a1f-5ece7f062db7",
      "name": "Expand Posts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// The scheduled-posts endpoint atomically claims due posts (flips them to\n// 'publishing') and returns them as { success, data:[...] }. Emit one item per\n// post so 'Trigger Publish' fires WF8b once per post. Empty -> no items -> no-op.\nconst resp = $input.first().json || {};\nconst rows = Array.isArray(resp.data) ? resp.data : [];\nreturn rows.map((r) => ({ json: r }));"
      }
    },
    {
      "id": "5d55266a-a463-468d-bdc6-f1ce3b638202",
      "name": "Trigger Publish",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        672,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $vars.N8N_SOCIAL_PUBLISH_WEBHOOK_URL }}",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { \"orgId\": $json.organization_id, \"postId\": $json.id, \"platforms\": $json.platforms } }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    }
  ],
  "connections": {
