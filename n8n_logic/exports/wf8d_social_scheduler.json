    {
      "id": "d2f2a625-8767-43b3-8371-ac428327a9d2",
      "name": "Claim Due Posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        224,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.NEXUS_APP_URL }}/api/internal/n8n/scheduled-posts",
        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            {
