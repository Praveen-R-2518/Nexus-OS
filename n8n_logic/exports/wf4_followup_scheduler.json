    {
      "parameters": {
        "jsCode": "const rows = [];\n\nfor (const item of $input.all()) {\n  const data = item.json;\n\n  if (Array.isArray(data?.body)) {\n    rows.push(...data.body);\n  } else if (Array.isArray(data)) {\n    rows.push(...data);\n  } else if (Array.isArray(data?.data)) {\n    rows.push(...data.data);\n  } else if (data && data.id) {\n    rows.push(data);\n  }\n}\n\nreturn rows.map(row => ({ json: row }));"
      },
