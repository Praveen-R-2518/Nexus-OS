        "resource": "chat",
        "chatModel": "gpt-4o",
        "prompt": {
          "messages": [
            { "role": "system", "content": "=You are writing a short, polite follow-up message for {{ ((Array.isArray($('Fetch Business Profile').item.json) ? $('Fetch Business Profile').item.json[0] : $('Fetch Business Profile').item.json).name) || 'the business' }}.\nBusiness tone: {{ ((Array.isArray($('Fetch Business Profile').item.json) ? $('Fetch Business Profile').item.json[0] : $('Fetch Business Profile').item.json).tone) || 'warm and professional' }}\n\nRules:\n1. This is a follow-up because the customer has not responded\n2. Keep it to 2-3 sentences only\n3. Be warm but create gentle urgency - the customer's inquiry is still open\n4. Do NOT repeat pricing or detailed information\n5. End with a simple question or a single call to action\n6. Sound human, not templated\n7. Return ONLY the message text. No subject. No formatting." },
            { "content": "=Customer name: {{ $('Process Each Follow-up').item.json.leads.customer_name }}\nOriginal intent: {{ $('Process Each Follow-up').item.json.leads.intent }}\nOriginal message: {{ ((Array.isArray($('Fetch Original Conversation').item.json) ? $('Fetch Original Conversation').item.json[0] : $('Fetch Original Conversation').item.json).message) || '' }}\nDays since last contact: 2" }
