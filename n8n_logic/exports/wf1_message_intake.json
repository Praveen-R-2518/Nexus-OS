      "main": [
        [{ "node": "Trigger WF2", "type": "main", "index": 0 }],
        [{ "node": "Trigger WF2", "type": "main", "index": 0 }]
      ]
    },
    "Trigger WF2": {
      "main": [
        [{ "node": "Respond OK", "type": "main", "index": 0 }],
        [{ "node": "Respond OK", "type": "main", "index": 0 }]
      ]
    },
    "Log Intake Error": { "main": [[{ "node": "Respond Error", "type": "main", "index": 0 }]] }
  },
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "nexus/intake", "responseMode": "responseNode", "options": {} },
