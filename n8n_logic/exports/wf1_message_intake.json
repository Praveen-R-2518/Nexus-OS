        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  workflow_name: 'intake',\n  step: 'message_stored',\n  result: 'success',\n  payload: {\n    conversation_id: $('Insert Conversation').item.json.body[0].id,\n    source: $('Normalize Payload').item.json.source\n  },\n  timestamp: $now.toISO()\n} }}",
        "options": { "response": { "response": { "neverError": true, "responseFormat": "json" } } }
      },
      "id": "1b2c0599-9b81-4186-9edd-cf605031c3eb",
