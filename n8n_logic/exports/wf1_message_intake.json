        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  conversation_id: $('Insert Conversation').item.json.body[0].id,\n  message: $('Normalize Payload').item.json.message,\n  customer_name: $('Normalize Payload').item.json.customer_name,\n  customer_email: $('Normalize Payload').item.json.customer_email\n} }}",
        "options": { "response": { "response": { "neverError": true, "responseFormat": "json" } }, "timeout": 15000 }
