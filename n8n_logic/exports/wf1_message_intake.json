      "typeVersion": 2.3,
      "position": [-784, 128],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
          "conditions": [
            {
              "id": "has-tenant",
              "leftValue": "={{ Boolean($json.body && ($json.body.team_id || $json.body.workspace_id)) }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "aa000002-0000-4000-8000-000000000002",
      "name": "Reject Missing Tenant",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [-528, 320],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: false, error: 'team_id or workspace_id required' }) }}",
        "options": { "responseCode": 400 }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "source", "name": "source", "value": "={{ $json.body.source || 'demo' }}", "type": "string" },
            { "id": "customer_name", "name": "customer_name", "value": "={{ ($json.body.customer_name || '').trim() }}", "type": "string" },
            { "id": "customer_email", "name": "customer_email", "value": "={{ ($json.body.customer_email || '').toLowerCase().trim() }}", "type": "string" },
            { "id": "message", "name": "message", "value": "={{ ($json.body.message || '').trim() }}", "type": "string" },
            { "id": "received_at", "name": "received_at", "value": "={{ $now.toISO() }}", "type": "string" },
            { "id": "status", "name": "status", "value": "unread", "type": "string" },
            { "id": "raw_payload", "name": "raw_payload", "value": "={{ JSON.stringify($json.body || {}) }}", "type": "string" },
            { "id": "team_id", "name": "team_id", "value": "={{ $json.body.team_id || '' }}", "type": "string" },
            { "id": "workspace_id", "name": "workspace_id", "value": "={{ $json.body.workspace_id || '' }}", "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "3232633f-84f6-46f9-9bae-1de8a400a40d",
      "name": "Normalize Payload",
