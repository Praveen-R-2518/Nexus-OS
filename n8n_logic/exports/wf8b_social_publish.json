      ],
      "parameters": {
        "method": "GET",
        "url": "={{ (($vars.NEXUS_APP_URL || 'https://nexusos.knurdz.org').replace(/\\/$/, '')) + '/api/internal/n8n/social-credentials?organization_id=' + $('Publish Request').first().json.body.orgId }}",
        "sendHeaders": true,
        "headerParameters": {
