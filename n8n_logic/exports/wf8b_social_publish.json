      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2040,
        300
      ],
      "parameters": {
        "method": "PATCH",
        "url": "=https://xuvodbcdmfhlbldbvwvt.supabase.co/rest/v1/social_posts?id=eq.{{ $('Publish Request').first().json.body.postId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { status: \"published\", published_at: $now.toISO() } }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth"
      },
      "credentials": {
        "httpCustomAuth": {
          "id": "4rfwTEeSitzS3JeQ",
          "name": "Supabase API"
        }
      }
    },
    {
      "id": "82da5c2d-77cc-4b1e-9684-f52924394830",
      "name": "Return Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1344,
        192
      ],
      "parameters": {}
    },
    {
      "id": "66265011-8b0b-4961-bc92-7ec0a372951e",
      "name": "Build Platform Post Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1290,
        300
      ],
      "parameters": {
        "jsCode": "const post = $('Flatten Post Data').first().json;\nconst resp = $input.first().json;\nif (resp && resp.success === false) {\n  throw new Error(resp.error || 'Failed to fetch social credentials');\n}\nconst creds = Array.isArray(resp?.data) ? resp.data : [];\nconst platforms = post.platforms || [];\nconst captions = post.captions || {};\nconst mediaUrl = post.mediaUrl;\nconst postId = post.id;\n\nconst SUPPORTED = ['instagram', 'facebook', 'x'];\nconst items = [];\n\nfor (const platform of platforms) {\n  if (!SUPPORTED.includes(platform)) {\n    continue;\n  }\n  const cred = creds.find(c => c.platform === platform);\n  if (!cred) {\n    continue;\n  }\n  items.push({\n    json: {\n      platform,\n      caption: (captions[platform] && captions[platform].caption) || '',\n      platformToken: cred.access_token,\n      mediaUrl,\n      postId\n    }\n  });\n}\n\nreturn items;",
        "mode": "runOnceForAllItems"
      }
    }
  ],
