      "parameters": {
        "method": "POST",
        "url": "={{ $json.platform === \"instagram\" ? \"https://graph.instagram.com/v18.0/ig/me/media\" : $json.platform === \"facebook\" ? \"https://graph.facebook.com/v18.0/me/feed\" : \"https://api.twitter.com/2/tweets\" }}",
        "sendHeaders": true,
