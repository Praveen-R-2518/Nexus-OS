        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ { text: $json.caption } }}"
      }
    },
    {
      "id": "60e81850-c7b2-44b1-967a-09f0663fc7b5",
      "name": "Process Each Platform",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
