# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: used by existing API routes and Gmail credential encryption
SUPABASE_SERVICE_ROLE_KEY=

# 32+ character secret; hashed to a 32-byte AES-256 key for IMAP password storage
# Required for /api/gmail/test-imap — set in .env.local (server-only), then restart `next dev`.
ENCRYPTION_KEY=

# Optional: enables additive secure internal workflow endpoints under /api/internal/n8n/*
# Do not switch live n8n workflows until parity tests pass.
N8N_INGEST_TOKEN=

# Dodo Payments (wire when ready)
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
