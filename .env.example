# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public origin used for Supabase Auth email redirects in production.
# Example: https://nexus-os.example.com
NEXT_PUBLIC_SITE_URL=

# Server-only: used by existing API routes and Gmail credential encryption
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API (server/local only; never expose in client)
# Used by `npm run check:auth-email` and `npm run fix:auth-email`.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=xuvodbcdmfhlbldbvwvt

# Supabase Auth email delivery repair/check settings
SUPABASE_AUTH_SITE_URL=
SUPABASE_AUTH_REDIRECT_URLS=
SUPABASE_AUTH_EMAIL_RATE_LIMIT=100
SUPABASE_AUTH_DISABLE_SEND_EMAIL_HOOK=true

# Existing SMTP provider credentials for Supabase Auth email delivery.
# Required only when running `npm run fix:auth-email` to patch SMTP.
SUPABASE_SMTP_ADMIN_EMAIL=
SUPABASE_SMTP_HOST=
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=
SUPABASE_SMTP_PASS=
SUPABASE_SMTP_SENDER_NAME=Nexus OS

# 32+ character secret; hashed to a 32-byte AES-256 key for IMAP password storage
# Required for /api/gmail/test-imap — set in .env.local (server-only), then restart `next dev`.
ENCRYPTION_KEY=

# n8n auth hardening (docs/n8n_workspace_env.md) — three token types, narrowing trust from one
# broad shared secret:
#   N8N_BOOTSTRAP_TOKEN  — scheduler/claim endpoints that run BEFORE any job exists
#                          (gmail-sync, gmail-backfill, inbound-replay, scheduled-posts GET,
#                          conversations create, outbound-jobs claim).
#   N8N_INGEST_TOKEN     — legacy broad token. Kept as a fallback for N8N_BOOTSTRAP_TOKEN and as
#                          a transition-period fallback (logged) on job-scoped routes. Rotate off
#                          once n8n workflows mint job tokens; do not add new call sites for it.
#   N8N_WEBHOOK_TOKEN    — outbound direction: Header Auth the APP sends when calling INTO n8n
#                          webhooks (approval-trigger, gmail-inbound, publish-social-post).
#                          Configure n8n's webhook trigger nodes with matching Header Auth.
# Job-scoped callbacks (send-reply, autopilot-send, post-result, ai-usage, match-embeddings,
# *-credentials) use short-lived single-use tokens minted server-side — see lib/n8n-job-tokens.ts.
# Do not switch live n8n workflows until parity tests pass.
N8N_BOOTSTRAP_TOKEN=
N8N_INGEST_TOKEN=
N8N_WEBHOOK_TOKEN=

# Gmail OAuth2 (Google Cloud Console)
# Register redirect URI: {NEXT_PUBLIC_SITE_URL}/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta (WhatsApp + Instagram + Facebook Messenger)
# Register redirect URI: {NEXT_PUBLIC_SITE_URL}/api/meta/callback
# Webhook callback URL: {NEXT_PUBLIC_SITE_URL}/api/meta/webhook
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# n8n Cloud: forwards verified Meta payloads to {N8N_WEBHOOK_BASE_URL}/webhook/gmail-inbound
N8N_WEBHOOK_BASE_URL=
NEXUS_TEAM_ID=

# OpenAI — app host ONLY. Never provision OPENAI_API_KEY in n8n; classification/draft/chat
# routes call OpenAI from the Next.js server (see app/api/internal/n8n/ai/*).
OPENAI_API_KEY=
# Optional OpenAI-compatible endpoint override. For Azure OpenAI use the v1 surface, e.g.
#   OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1
# (accepts standard Bearer auth with the Azure key in OPENAI_API_KEY). Unset = api.openai.com.
OPENAI_BASE_URL=
# Per-workload model overrides (Azure: DEPLOYMENT names). Specific vars do NOT fall back to
# OPENAI_MODEL. Note gpt-5-family deployments reject `max_tokens` (code uses
# max_completion_tokens) — see lib/ai/provider.ts.
# OPENAI_MODEL=gpt-4.1                # chat agent + posts captions (default gpt-4o)
# OPENAI_MODEL_DRAFT=gpt-4.1          # reply drafting (default gpt-4o)
# OPENAI_MODEL_CLASSIFY=gpt-5.4-mini  # classification (default gpt-4o-mini)
# OPENAI_MODEL_REPORT=gpt-5.4-mini    # buy-back report summary (default gpt-4o-mini)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large  # default text-embedding-3-small; Azure: deployment name
# OPENAI_IMAGE_MODEL=                 # posts image generation — unset until an image deployment exists
# Split-provider mode: when the primary endpoint (e.g. Azure) has no embedding/image
# deployments, point those purposes at a plain OpenAI key. The pair is atomic — an override key
# without its own BASE_URL means api.openai.com (never inherits OPENAI_BASE_URL).
# OPENAI_EMBED_API_KEY=
# OPENAI_EMBED_BASE_URL=
# OPENAI_IMAGE_API_KEY=
# OPENAI_IMAGE_BASE_URL=
# AI_PROVIDER=mock  — deterministic fixtures, no network (CI/tests only)

# Feature flags (client-visible; default off until launch gates pass)
NEXT_PUBLIC_FEATURE_META_INBOX=false
NEXT_PUBLIC_FEATURE_SOCIAL_PUBLISHING=false
NEXT_PUBLIC_FEATURE_BILLING=false

# Outbound send transport: `sandbox` (default, no real Gmail/Meta sends), empty or `live` for
# production sends after gmail.send scope + mailbox reconsent. See docs/LAUNCH_ACTIVATION.md.
CHANNEL_SENDER_TRANSPORT=sandbox

# Meta outbound: set true only after App Review and live credential binding in n8n.
META_SEND_ENABLED=false

# Social publishing (Posts studio)
# app → WF8b publish webhook; required for /api/posts/publish to trigger n8n.
N8N_SOCIAL_PUBLISH_WEBHOOK_URL=
# X (Twitter) + LinkedIn OAuth apps for /api/social/connect
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Public app origin used by a few client-side callers (falls back to NEXT_PUBLIC_SITE_URL)
NEXT_PUBLIC_APP_URL=

# Dodo Payments (wire when ready)
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
