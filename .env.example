# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Public origin used for Supabase Auth email redirects in production.
# Example: https://nexus-os.example.com
NEXT_PUBLIC_SITE_URL=

# Server-only: used by existing API routes and Gmail credential encryption
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API (server/local only; never expose in client)
# Used by `npm run check:auth-email` and `npm run fix:auth-email`.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=xuvodbcdmfhlbldbvwvt

# Supabase Auth email delivery repair/check settings
SUPABASE_AUTH_SITE_URL=
SUPABASE_AUTH_REDIRECT_URLS=
SUPABASE_AUTH_EMAIL_RATE_LIMIT=100
SUPABASE_AUTH_DISABLE_SEND_EMAIL_HOOK=true

# Existing SMTP provider credentials for Supabase Auth email delivery.
# Required only when running `npm run fix:auth-email` to patch SMTP.
SUPABASE_SMTP_ADMIN_EMAIL=
SUPABASE_SMTP_HOST=
SUPABASE_SMTP_PORT=587
SUPABASE_SMTP_USER=
SUPABASE_SMTP_PASS=
SUPABASE_SMTP_SENDER_NAME=Nexus OS

# 32+ character secret; hashed to a 32-byte AES-256 key for IMAP password storage
# Required for /api/gmail/test-imap — set in .env.local (server-only), then restart `next dev`.
ENCRYPTION_KEY=

# Optional: enables additive secure internal workflow endpoints under /api/internal/n8n/*
# Do not switch live n8n workflows until parity tests pass.
N8N_INGEST_TOKEN=

# Gmail OAuth2 (Google Cloud Console)
# Register redirect URI: {NEXT_PUBLIC_SITE_URL}/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta (WhatsApp + Instagram + Facebook Messenger)
# Register redirect URI: {NEXT_PUBLIC_SITE_URL}/api/meta/callback
# Webhook callback URL: {NEXT_PUBLIC_SITE_URL}/api/meta/webhook
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# n8n Cloud: forwards verified Meta payloads to {N8N_WEBHOOK_BASE_URL}/webhook/gmail-inbound
N8N_WEBHOOK_BASE_URL=
NEXUS_TEAM_ID=

# Dodo Payments (wire when ready)
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
