# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Secrets & local env — ignore all variants; whitelist safe templates only
.env
.env.*
.envrc

# Allowed env templates (rename / copy locally; never put real secrets in these files)
!.env.example
!.env.sample
!.env*.example

# vercel / deploy
.vercel

# typescript
*.tsbuildinfo

# ESLint cache
.eslintcache

# Turborepo
.turbo

# Trigger.dev local dev / build caches
.trigger

# Common credential/key filenames (prefer env vars instead)
**/credentials.json
**/service-account*.json
*-private-key.pem
*.p12
*.pfx

# IDE / editor (optional junk; uncomment if team agrees)
#.idea/
